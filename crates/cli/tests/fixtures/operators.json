  },
  {
    "operator_type": "command",
    "description": "Execute shell commands and capture output",
    "params_schema": {
      "type": "object",
      "properties": {
        "command": {
          "type": "string",
          "description": "Shell command to execute"
        },
        "capture_output": {
          "type": "boolean",
          "description": "Capture stdout and stderr",
          "default": true
        }
      },
      "required": ["command"]
    }
  },
  {
    "operator_type": "assert_completed",
